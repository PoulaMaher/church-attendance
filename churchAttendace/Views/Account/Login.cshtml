@model LoginViewModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "تسجيل الدخول";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap');

    :root {
        --c-gold: #C5A059;
        --c-gold-light: #DFCDA6;
        --c-dark: #121E2A;
        --c-dark-soft: #1D2D3E;
        --c-sand: #F9F7F1;
        --c-white: #FFFFFF;
        --font-main: 'Cairo', sans-serif;
    }

    body {
        font-family: var(--font-main);
        background: radial-gradient(circle at center, var(--c-sand) 0%, #EAE5D9 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
    }

    .auth-wrapper {
        width: 100%;
        max-width: 420px;
        padding: 1.5rem;
        margin: auto;
    }

    .auth-card {
        background: var(--c-white);
        border-radius: 24px;
        box-shadow: 0 20px 40px rgba(18, 30, 42, 0.08);
        position: relative;
        border: 1px solid rgba(197, 160, 89, 0.15);
    }

        .auth-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, var(--c-gold), var(--c-gold-light), var(--c-gold));
            border-radius: 24px 24px 0 0;
        }

    .auth-header {
        padding: 2.5rem 2rem 1.5rem;
        text-align: center;
    }

    .auth-icon-wrapper {
        width: 75px;
        height: 75px;
        margin: 0 auto 1.5rem;
        background: linear-gradient(135deg, var(--c-gold-light), var(--c-gold));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 20px rgba(197, 160, 89, 0.4);
        color: var(--c-white);
        font-size: 2.2rem;
    }

    .auth-body {
        padding: 0 2.5rem 2.5rem;
    }

    .custom-input {
        background-color: var(--c-sand);
        border: 2px solid transparent;
        border-radius: 14px;
        padding: 0.9rem 1.2rem;
        color: var(--c-dark);
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .custom-input:focus {
            background-color: var(--c-white);
            border-color: var(--c-gold);
            box-shadow: 0 0 0 4px rgba(197, 160, 89, 0.1);
            outline: none;
        }

        .custom-input::placeholder {
            color: #A0AAB5;
            font-weight: 400;
        }

    .custom-label {
        color: var(--c-dark-soft);
        font-weight: 700;
        margin-bottom: 0.6rem;
        display: block;
        font-size: 0.95rem;
    }

    .custom-checkbox {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

        .custom-checkbox .form-check-input {
            width: 1.25rem;
            height: 1.25rem;
            margin: 0;
            border-color: #D1D5DB;
            cursor: pointer;
        }

            .custom-checkbox .form-check-input:checked {
                background-color: var(--c-gold);
                border-color: var(--c-gold);
            }

        .custom-checkbox .form-check-label {
            color: var(--c-dark-soft);
            font-weight: 600;
            cursor: pointer;
            font-size: 0.9rem;
        }

    .btn-gold {
        background: linear-gradient(135deg, var(--c-gold-light), var(--c-gold));
        color: var(--c-white);
        border: none;
        border-radius: 14px;
        font-weight: 700;
        padding: 1rem;
        font-size: 1.1rem;
        transition: all 0.3s ease;
    }

        .btn-gold:hover {
            background: linear-gradient(135deg, var(--c-gold), #b38b47);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(197, 160, 89, 0.4);
            color: var(--c-white);
        }

    .alert-danger {
        background-color: #fdf2f2;
        border-color: #f9d6d6;
        color: #d9534f;
        border-radius: 12px;
    }
</style>

<div class="auth-wrapper">
    <div class="auth-card animate__animated animate__zoomIn">

        <div class="auth-header">
            <div class="auth-icon-wrapper">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h1 class="h4 fw-bold" style="color: var(--c-dark);">تسجيل الدخول</h1>
            <p class="small mt-2 mb-0" style="color: var(--c-dark-soft); opacity: 0.8;">مرحباً بعودتك إلى نظام إدارة الحضور</p>
        </div>

        <div class="auth-body">
            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger px-3 py-2 small mb-4"></div>

                <div class="mb-4">
                    <label asp-for="Email" class="custom-label">البريد الإلكتروني</label>
                    <input asp-for="Email" class="form-control custom-input" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block fw-bold"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="custom-label">كلمة المرور</label>
                    <input asp-for="Password" class="form-control custom-input" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block fw-bold"></span>
                </div>

                <div class="mb-4 custom-checkbox">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label">تذكرني على هذا الجهاز</label>
                </div>

                <button type="submit" class="btn btn-gold w-100 d-flex align-items-center justify-content-center gap-2 mt-2">
                    <span>تسجيل الدخول</span>
                    <i class="bi bi-box-arrow-in-left"></i>
                </button>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}