@model HomeViewModel
@{
    Layout = "_HomeLayout";
    ViewData["Title"] = "الصفحة الرئيسية";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap');

    :root {
        --c-gold: #C5A059;
        --c-gold-light: #DFCDA6;
        --c-dark: #121E2A;
        --c-dark-soft: #1D2D3E;
        --c-sand: #F9F7F1;
        --c-white: #FFFFFF;
        --font-main: 'Cairo', sans-serif;
    }

    body {
        background-color: var(--c-sand);
        font-family: var(--font-main);
        color: var(--c-dark);
    }

    .hero-wrapper {
        padding: 2rem 0 3rem;
        background: radial-gradient(circle at center, rgba(197, 160, 89, 0.05) 0%, rgba(249, 247, 241, 0) 70%);
    }

    .church-arch-frame {
        position: relative;
        padding: 4px;
        background: linear-gradient(135deg, var(--c-gold), var(--c-gold-light), var(--c-gold));
        border-radius: 60px 60px 10px 10px;
        box-shadow: 0 10px 20px rgba(18, 30, 42, 0.15);
        transition: all 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .church-arch-inner {
        background-color: var(--c-white);
        border-radius: 56px 56px 8px 8px;
        overflow: hidden;
        height: 100%;
        position: relative;
    }

    .hero-img-portrait {
        height: 130px;
    }

    .hero-img-main {
        height: 160px;
    }

    .hero-title {
        font-weight: 800;
        color: var(--c-dark);
        margin-top: 0.8rem;
        font-size: 0.85rem;
    }

    .hero-subtitle {
        color: var(--c-gold);
        font-weight: 700;
        font-size: 0.7rem;
        margin-bottom: 0.2rem;
    }

    @@media (min-width: 768px) {
        .hero-wrapper {
            padding: 4rem 0 5rem;
        }

        .church-arch-frame {
            padding: 8px;
            border-radius: 120px 120px 15px 15px;
            box-shadow: 0 20px 40px rgba(18, 30, 42, 0.15);
        }

        .church-arch-inner {
            border-radius: 112px 112px 10px 10px;
        }

        .hero-img-portrait {
            height: 320px;
        }

        .hero-img-main {
            height: 420px;
        }

        .hero-title {
            font-size: 1.5rem;
            margin-top: 1.5rem;
        }

        .hero-subtitle {
            font-size: 1.1rem;
        }
    }

    .church-arch-frame:hover {
        transform: translateY(-12px);
        box-shadow: 0 30px 50px rgba(197, 160, 89, 0.3);
    }

    .church-arch-frame::after {
        content: '';
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        width: 30px;
        height: 30px;
        background: radial-gradient(circle, var(--c-gold) 20%, transparent 70%);
        opacity: 0;
        transition: opacity 0.5s ease;
    }

    .church-arch-frame:hover::after {
        opacity: 1;
    }

    .elegant-carousel {
        padding-bottom: 2rem;
    }

    .elegant-card {
        background: var(--c-white);
        border-radius: 20px;
        border: 1px solid rgba(197, 160, 89, 0.2);
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        transition: transform 0.4s ease;
    }

        .elegant-card:hover {
            transform: translateY(-5px);
        }

        .elegant-card img {
            border-radius: 16px;
            border: 3px solid var(--c-sand);
        }

    .icon-gold {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 50px;
        height: 50px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--c-gold-light), var(--c-gold));
        color: var(--c-white);
        box-shadow: 0 5px 15px rgba(197, 160, 89, 0.4);
    }

    .elegant-carousel .carousel-indicators {
        bottom: -15px;
    }

        .elegant-carousel .carousel-indicators button {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background-color: var(--c-gold-light);
            border: none;
            margin: 0 6px;
            opacity: 0.6;
            transition: all 0.3s ease;
        }

            .elegant-carousel .carousel-indicators button.active {
                background-color: var(--c-gold);
                transform: scale(1.4);
                opacity: 1;
            }

    .custom-carousel-btn {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, var(--c-gold-light), var(--c-gold));
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
        opacity: 0.8;
        box-shadow: 0 5px 15px rgba(197, 160, 89, 0.4);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

        .custom-carousel-btn i {
            color: var(--c-white);
            font-size: 1.5rem;
        }

        .custom-carousel-btn:hover {
            opacity: 1;
            background: var(--c-dark);
            box-shadow: 0 8px 20px rgba(18, 30, 42, 0.3);
        }

    @@media (min-width: 768px) {
        .carousel-control-prev {
            left: -20px;
            right: auto;
        }

        .carousel-control-next {
            right: -20px;
            left: auto;
        }
    }

    .reply-thread {
        border-right: 3px dashed var(--c-gold-light);
        padding-right: 1.5rem;
        margin-right: 1rem;
    }

    .reply-item {
        position: relative;
        background: var(--c-sand);
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 2rem;
    }

        .reply-item::before {
            content: '';
            position: absolute;
            right: -28px;
            top: 20px;
            width: 14px;
            height: 14px;
            background: var(--c-gold);
            border-radius: 50%;
            box-shadow: 0 0 0 4px var(--c-white);
        }

    .admin-response-box {
        background: var(--c-white);
        border-radius: 8px;
        border: 1px solid rgba(197, 160, 89, 0.3);
        border-right: 4px solid var(--c-gold);
        padding: 1rem;
        margin-top: 1rem;
    }

    .custom-form-container {
        background: var(--c-dark);
        color: var(--c-white);
        border-radius: 20px;
        position: relative;
        overflow: hidden;
    }

        .custom-form-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, var(--c-gold), var(--c-gold-light), var(--c-gold));
        }

    .custom-input {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--c-white);
        border-radius: 12px;
    }

        .custom-input:focus {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--c-gold);
            color: var(--c-white);
            box-shadow: 0 0 0 4px rgba(197, 160, 89, 0.1);
        }

        .custom-input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

    .btn-gold {
        background: linear-gradient(135deg, var(--c-gold-light), var(--c-gold));
        color: var(--c-white);
        border: none;
        border-radius: 12px;
        font-weight: 700;
        transition: all 0.3s ease;
    }

        .btn-gold:hover {
            background: linear-gradient(135deg, var(--c-gold), #b38b47);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(197, 160, 89, 0.4);
            color: var(--c-white);
        }
</style>

<div class="container pb-5">

    <div class="hero-wrapper mb-5">
        <div class="row align-items-end justify-content-center text-center g-2 g-md-4 px-2">

            <div class="col-4 order-1 animate__animated animate__fadeInRight">
                <div class="church-arch-frame mx-auto" style="max-width: 260px;">
                    <div class="church-arch-inner">
                        <img src="~/images/pope_tawadros.png" alt="البابا تواضروس" class="w-100 hero-img-portrait object-fit-cover" onerror="this.style.display='none'; this.nextElementSibling.classList.remove('d-none');" />
                        <div class="img-fallback d-none w-100 hero-img-portrait d-flex align-items-center justify-content-center">
                            <i class="bi bi-person-video2 fs-1" style="color: var(--c-gold);"></i>
                        </div>
                    </div>
                </div>
                <h2 class="hero-subtitle mt-2 mt-md-4">قداسة البابا</h2>
                <h3 class="hero-title">الأنبا تواضروس</h3>
            </div>

            <div class="col-4 order-2 animate__animated animate__fadeInDown z-3">
                <div class="church-arch-frame mx-auto" style="max-width: 320px;">
                    <div class="church-arch-inner">
                        <img src="~/images/church.png" alt="كنيسة مارمينا العجايبي" class="w-100 hero-img-main object-fit-cover" onerror="this.style.display='none'; this.nextElementSibling.classList.remove('d-none');" />
                        <div class="img-fallback d-none w-100 hero-img-main d-flex align-items-center justify-content-center">
                            <i class="bi bi-building fs-1" style="color: var(--c-gold);"></i>
                        </div>
                    </div>
                </div>
                <h1 class="hero-subtitle mt-2 mt-md-4">كنيسة الشهيد العظيم</h1>
                <h2 class="hero-title">مارمينا العجايبي</h2>
            </div>

            <div class="col-4 order-3 animate__animated animate__fadeInLeft">
                <div class="church-arch-frame mx-auto" style="max-width: 260px;">
                    <div class="church-arch-inner">
                        <img src="~/images/anba_marqorious.png" alt="الانبا مرقوريوس" class="w-100 hero-img-portrait object-fit-cover" onerror="this.style.display='none'; this.nextElementSibling.classList.remove('d-none');" />
                        <div class="img-fallback d-none w-100 hero-img-portrait d-flex align-items-center justify-content-center">
                            <i class="bi bi-person-badge fs-1" style="color: var(--c-gold);"></i>
                        </div>
                    </div>
                </div>
                <h2 class="hero-subtitle mt-2 mt-md-4">نيافة الأنبا</h2>
                <h3 class="hero-title">مرقوريوس</h3>
            </div>

        </div>
    </div>

    <div class="mb-5 animate__animated animate__fadeInUp">

        <div id="churchStoryCarousel" class="carousel slide elegant-carousel" data-bs-ride="carousel" data-bs-interval="5000">

            <div class="carousel-indicators">
                <button type="button" data-bs-target="#churchStoryCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#churchStoryCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
            </div>

            <div class="carousel-inner px-2 px-md-5 pb-3">

                <div class="carousel-item active">
                    <div class="elegant-card p-4 p-md-5 mx-auto">
                        <div class="row align-items-center g-4">
                            <div class="col-12 col-md-5">
                                <div class="position-relative overflow-hidden shadow-sm" style="height: 280px; border-radius: 20px;">
                                    <img src="~/images/church.png" alt="تأسيس الكنيسة" class="w-100 h-100 object-fit-cover" onerror="this.style.display='none';" />
                                </div>
                            </div>
                            <div class="col-12 col-md-7">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="icon-gold me-3 ms-0">
                                        <i class="bi bi-bank fs-4"></i>
                                    </div>
                                    <h3 class="h4 fw-bold mb-0" style="color: var(--c-dark);">تأسيس الكنيسة وتدشينها</h3>
                                </div>
                                <p class="lh-lg fs-6 app-preline mb-0" style="color: var(--c-dark-soft);">@Model.Box1Text</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="carousel-item">
                    <div class="elegant-card p-4 p-md-5 mx-auto">
                        <div class="row align-items-center g-4">
                            <div class="col-12 col-md-5">
                                <div class="position-relative overflow-hidden shadow-sm" style="height: 280px; border-radius: 20px;">
                                    <img src="~/images/ster_mar_mina.png" alt="صورة القديس مارمينا على الستر" class="w-100 h-100 object-fit-cover" onerror="this.style.display='none';" />
                                </div>
                            </div>
                            <div class="col-12 col-md-7">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="icon-gold me-3 ms-0">
                                        <i class="bi bi-stars fs-4"></i>
                                    </div>
                                    <h3 class="h4 fw-bold mb-0" style="color: var(--c-dark);">معجزة ظهور مارمينا علي ستر الهيكل</h3>
                                </div>
                                <p class="lh-lg fs-6 app-preline mb-0" style="color: var(--c-dark-soft);">@Model.Box2Text</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>

            <button class="carousel-control-prev w-auto" type="button" data-bs-target="#churchStoryCarousel" data-bs-slide="prev">
                <span class="custom-carousel-btn" aria-hidden="true">
                    <i class="bi bi-chevron-right"></i>
                </span>
                <span class="visually-hidden">السابق</span>
            </button>
            <button class="carousel-control-next w-auto" type="button" data-bs-target="#churchStoryCarousel" data-bs-slide="next">
                <span class="custom-carousel-btn" aria-hidden="true">
                    <i class="bi bi-chevron-left"></i>
                </span>
                <span class="visually-hidden">التالي</span>
            </button>

        </div>
    </div>

    <div class="row g-5">

        @if (Model.ComplaintsWithReplies?.Count > 0)
        {
            <div class="col-12 col-lg-7">
                <div class="mb-4 d-flex align-items-center">
                    <i class="bi bi-envelope-open fs-3 me-2 ms-0" style="color: var(--c-gold);"></i>
                    <h2 class="h4 fw-bold mb-0" style="color: var(--c-dark);">سجل الردود والقرارات</h2>
                </div>

                <div class="reply-thread">
                    @foreach (var item in Model.ComplaintsWithReplies)
                    {
                        <div class="reply-item animate__animated animate__fadeInUp">
                            <div class="mb-2 d-flex justify-content-between align-items-center">
                                <span class="fw-bold" style="color: var(--c-dark-soft);">الرسالة المُقدمة</span>
                            </div>
                            <p class="app-preline mb-0" style="color: var(--c-dark);">@item.Text</p>

                            <div class="admin-response-box">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="badge" style="background: var(--c-gold); color: var(--c-white);">رد الإدارة</span>
                                    <small style="color: var(--c-dark-soft); font-weight: 600;">@item.RepliedAt.ToString("yyyy-MM-dd")</small>
                                </div>
                                <p class="mb-0 app-preline" style="color: var(--c-dark);">@item.Reply</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <div class="col-12 @(Model.ComplaintsWithReplies?.Count > 0 ? "col-lg-5" : "")">
            <div class="custom-form-container p-4 p-md-5 shadow-lg h-100 animate__animated animate__fadeInUp" style="animation-delay: 0.3s;">
                <div class="text-center mb-4">
                    <div class="icon-gold mx-auto mb-3" style="width: 60px; height: 60px; background: rgba(255,255,255,0.1); box-shadow: none;">
                        <i class="bi bi-pen fs-3 text-white"></i>
                    </div>
                    <h2 class="h4 fw-bold text-white mb-2">صندوق الشكاوى والمقترحات</h2>
                    <p class="small" style="color: rgba(255,255,255,0.6);">صوتك مسموع، اترك رسالتك هنا وسنقوم بالرد عليها</p>
                </div>

                <form asp-action="SubmitComplaint" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <textarea name="complaintText" id="complaintText" class="form-control custom-input p-3" style="height: 160px; resize: none;" placeholder="اكتب رسالتلك بصراحة هنا..." required></textarea>
                    </div>

                    <button type="submit" class="btn btn-gold w-100 py-3 d-flex align-items-center justify-content-center gap-2">
                        <span class="fs-5">إرسال الرسالة</span>
                        <i class="bi bi-send-fill fs-5"></i>
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>